# Copy this file to .env and fill in real values before deploying.
# Never commit .env to version control.

# !! IMPORTANT !! Generate a strong random key before production:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Then replace the placeholder below with the output.
SECRET_KEY=replace-with-a-random-64-char-string

# Anthropic API key for invoice photo scanning (AI auto-fill in inventory)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Set to "true" in production (HTTPS). Leave "false" for local HTTP development.
SESSION_COOKIE_SECURE=true

# Public URL for shareable bill links (e.g. your PythonAnywhere or Cloudflare tunnel URL)
# Leave unset for local development — bill links will use the browser's current origin.
# Example: https://shubhamnxtailoring.pythonanywhere.com
SHARE_BASE_URL=

# Cloudflare R2 storage for tailoring photos (cloth samples + measurements).
# Optional: leave all four blank to keep saving photos on local disk exactly
# as before. Set all four to offload new photo uploads to R2 instead (frees
# up server disk space — see the R2 setup steps in PROJECT.md).
#   R2_ACCOUNT_ID / R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY come from
#   Cloudflare dashboard -> R2 -> Manage API Tokens -> Create API Token.
#   R2_BUCKET_NAME is the bucket you create under R2 -> Create bucket.
#   R2_PUBLIC_URL is that bucket's public URL (R2 -> bucket -> Settings ->
#   Public Access -> enable r2.dev subdomain, or connect a custom domain).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
